{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": [
      "package.json",
      "package-lock.json",
      "vite.config.js",
      "index.html",
      "src/**",
      "public/**",
      "railway.json"
    ]
  },
  "deploy": {
    "startCommand": "npm run preview",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
